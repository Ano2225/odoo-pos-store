<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!--
            Caissier : voit ses caisses si allowed_pos est défini,
            sinon voit TOUTES les caisses (comportement par défaut Odoo).
        -->
        <record id="pos_config_cashier_rule" model="ir.rule">
            <field name="name">POS Config : caissier voit ses caisses uniquement</field>
            <field name="model_id" ref="point_of_sale.model_pos_config"/>
            <field name="domain_force">[('id', 'in', user.allowed_pos.ids)] if user.allowed_pos else [(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager : voit TOUTES les caisses sans restriction -->
        <record id="pos_config_manager_rule" model="ir.rule">
            <field name="name">POS Config : manager voit tout</field>
            <field name="model_id" ref="point_of_sale.model_pos_config"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('point_of_sale.group_pos_manager'))]"/>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!--
            Caissier : voit ses commandes si allowed_pos est défini,
            sinon voit TOUTES les commandes (comportement par défaut Odoo).
        -->
        <record id="pos_order_cashier_rule" model="ir.rule">
            <field name="name">POS Order : caissier voit ses commandes uniquement</field>
            <field name="model_id" ref="point_of_sale.model_pos_order"/>
            <field name="domain_force">[('config_id', 'in', user.allowed_pos.ids)] if user.allowed_pos else [(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('point_of_sale.group_pos_user'))]"/>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Manager : voit TOUTES les commandes sans restriction -->
        <record id="pos_order_manager_rule" model="ir.rule">
            <field name="name">POS Order : manager voit tout</field>
            <field name="model_id" ref="point_of_sale.model_pos_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('point_of_sale.group_pos_manager'))]"/>
            <field name="perm_read"   eval="True"/>
            <field name="perm_write"  eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

    </data>
</odoo>
